# IDs dos admins separados por vírgula (ex: 12345,67890)
ADMINS=

# Token do bot do BotFather
API_TOKEN=

# String de conexão do banco
# Postgres: postgresql://user:senha@host:5432/dbname
# SQLite (padrão se vazio): sqlite:///my_app.db
DATABASE_URL=

# ID do grupo de logs/notificações (negativo para supergroups)
GROUP_ID=

# Caminho do arquivo de log
LOG_PATH=Logs/session.log

# ID do canal de status (ping/uptime)
channelStatusId=
